#! /usr/bin/env python3
### vmshed: { "vms_all": [3], "vms_ci": null, "drbd_version_min": "9.0.0" }
#
# Correctness test: diskless primary correctly bumps UUID on first write with an
# absent diskful peer, so that peer can detect divergence and resync on reconnect.
#
# In a three-node cluster (diskless primary node_a, diskful node_b, diskful node_c),
# when node_c is absent during a write session on node_a, DRBD bumps the current UUID
# so that node_c can detect the new data generation on reconnect and perform a resync.
#
# This is a first-write scenario: node_c has a zero bitmap_uuid on node_b at the time
# of the write (it was connected and UpToDate when it disconnected), so
# diskless_primary_needs_uuid_bump() finds no evidence of a prior bump and correctly
# returns true. The UUID is bumped in both old and new code for this scenario; this
# test verifies the end-to-end correctness (UUID bump AND subsequent resync).
#
# For the regression test that catches the 9.2.18 diskless-primary fix (which fires
# when the only zero slot is my_node_id), see:
#   tests/diskless-primary-uuid-bump        (2-node case, always triggers the bug)
#   tests/day0-uuid-diskless-primary        (day-0 UUID variant, 2-node)

from python import drbdtest
from python.drbdtest import connections, log, peer_devices
from python import datatools




resource = drbdtest.setup_resource(nodes=3)
node_a = resource.nodes[0]       # diskless primary
node_b = resource.nodes[1]       # diskful, present throughout
node_c = resource.nodes[2]       # diskful, absent during the critical write window

resource.add_disk('10M', diskful_nodes=[node_b, node_c])

resource.up_wait()
resource.skip_initial_sync()

log('* Write baseline data while all three nodes are connected.')
node_a.write(direct=1)

log('* Disconnect node_c before the critical write session.')
conn_ca = connections(node_c, node_a)
conn_cb = connections(node_c, node_b)
conn_ca.disconnect()
conn_cb.disconnect()
peer_devices(node_a, node_c).event(r'peer-device .* replication:Off')
peer_devices(node_b, node_c).event(r'peer-device .* replication:Off')

log('* Record UUID before diskless-primary write session with node_c absent.')
uuid_before = node_b.get_current_uuid(node_a.id)
log('  UUID before write: %s' % uuid_before)

log('* Diskless primary node_a writes while node_c is absent (relies on autopromote).')
node_a.write(direct=1)

log('* Verify UUID was bumped so node_c can detect divergence on reconnect.')
uuid_after = node_b.get_current_uuid(node_a.id)
log('  UUID after write: %s' % uuid_after)
if uuid_after == uuid_before:
    raise Exception(
        'UUID was not bumped after diskless-primary write with node_c absent '
        '(before=%s after=%s)' % (uuid_before, uuid_after))
log('  UUID correctly bumped: %s -> %s' % (uuid_before, uuid_after))

log('* Reconnect node_c -- must resync, not silently become UpToDate.')
# node_c presents its old UUID on reconnect. node_b's current UUID has advanced;
# node_c's UUID is now in bitmap slot, triggering an incremental resync.
conn_cb.connect()
conn_ca.connect()

pd_cb = peer_devices(node_c, node_b)
pd_cb.event(r'peer-device .* replication:SyncTarget',
            no=r'peer-device .* replication:Established')
pd_cb.event(r'peer-device .* replication:Established')
log('  node_c resynced correctly.')

log('* Verify data integrity: node_c must hold the data written while it was absent.')
resource.down()
datatools.verify_data([node_b, node_c], size_mb=8, backing_disk=True)

log('* Shut down and clean up.')
resource.cluster.teardown()
